# Required: fal.ai API key. SERVER-ONLY. Never ship this to the iOS binary.
FAL_KEY=

# Optional: HTTP port (default 8080)
PORT=8080

# Base URL the iOS app reaches this service at. Used to build absolute asset URLs
# (hero.glb / backdrop.jpg) that the app downloads from THIS service instead of
# from expiring fal URLs. Example: https://diorama.example.com
PUBLIC_BASE_URL=http://localhost:8080
